# Metaflow's Airflow exporter requires a remote artifact datastore.
METAFLOW_DEFAULT_DATASTORE=s3
METAFLOW_DATASTORE_SYSROOT_S3=s3://replace-me/metaflow

# Use a shared metadata service so Airflow tasks expose one run lineage view.
METAFLOW_DEFAULT_METADATA=service
METAFLOW_SERVICE_URL=https://metaflow-metadata.example.com

# Configure workload identity in the scheduler/worker environment. Do not put
# static cloud credentials in this file.

# The generated DAG exposes `ds` as a parameter. The deployment wrapper must
# map the Airflow data interval or asset partition to `ds`; do not rely on the
# flow's deterministic local default for scheduled runs.
